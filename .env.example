# ========================================
# ML ENERGY CONSUMPTION - Environment Variables Template
# ========================================
#
# IMPORTANT: Copy this file to .env and fill in your actual values
# The .env file is gitignored and will never be committed
#
# cp .env.example .env
#

# ========================================
# SNOWFLAKE CREDENTIALS
# ========================================
SNOWFLAKE_ACCOUNT=your-org-your-account
SNOWFLAKE_USER=your-username
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_WAREHOUSE=ML_ENERGY_WH
SNOWFLAKE_DATABASE=ML_ENERGY_DB
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ========================================
# GCP CREDENTIALS
# ========================================
GCP_PROJECT_ID=your-gcp-project-id

# ========================================
# API KEYS
# ========================================
EIA_API_KEY=your-eia-api-key
ELEXON_API_KEY=your-elexon-api-key

# ========================================
# DATABRICKS (if needed for local testing)
# ========================================
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-token
